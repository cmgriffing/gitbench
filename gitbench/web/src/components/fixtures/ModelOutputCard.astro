---
interface Props {
  modelName: string;
  passed: boolean;
  similarity: number;
  output: string;
  error: string | null;
}

const { modelName, passed, similarity, output, error } = Astro.props;
const passCls = passed ? 'pass' : 'fail';
const encodedModel = encodeURIComponent(modelName);
---

<div class="card" style="padding: 1.25rem;">
  <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 0.75rem;">
    <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
      <a href={`/models/${encodedModel}`} style="
        font-family: var(--font-display); font-size: 0.85rem; font-weight: 700;
        color: var(--text); text-decoration: none;
      ">{modelName}</a>
      <span class="result-pill {passCls}">{passed ? 'PASS' : 'FAIL'}</span>
      <span style="font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600; color: var(--text);">
        {similarity}%
      </span>
    </div>
    <button
      type="button"
      data-text={output}
      style="background: none; border: 1px solid var(--border); color: var(--text-dim); border-radius: 4px; padding: 0.2rem 0.5rem; font-family: var(--font-mono); font-size: 0.6rem; cursor: pointer;"
      onclick="navigator.clipboard.writeText(this.getAttribute('data-text') || '')"
    >📋 Copy</button>
  </div>
  <div style="
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-mid);
    white-space: pre-wrap;
    word-break: break-word;
    line-height: 1.6;
    max-height: 300px;
    overflow-y: auto;
  ">{output || '(empty output)'}</div>
  {error && (
    <div style="margin-top: 0.5rem; font-family: var(--font-mono); font-size: 0.65rem; color: var(--fail);">
      Error: {error}
    </div>
  )}
</div>
