---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div style="margin-bottom: 1.5rem;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem;">
    <span style="font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent); opacity: 0.75;">
      Prompt
    </span>
    <button
      type="button"
      data-text={text}
      style="background: none; border: 1px solid var(--border); color: var(--text-dim); border-radius: 4px; padding: 0.2rem 0.5rem; font-family: var(--font-mono); font-size: 0.6rem; cursor: pointer;"
      onclick="navigator.clipboard.writeText(this.getAttribute('data-text') || '')"
    >📋 Copy</button>
  </div>
  <div style="
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-mid);
    white-space: pre-wrap;
    word-break: break-word;
    line-height: 1.7;
    max-height: 500px;
    overflow-y: auto;
  ">{text}</div>
</div>
