---
import Layout from '../components/Layout.astro';
import TimeSeriesChart from '../components/charts/TimeSeriesChart';
import { loadDataSync } from '../lib/data';
import type { GitBenchData } from '../lib/types';

const data = loadDataSync();

// Sort runs by timestamp descending
const sortedRuns = [...data.runs_meta].sort((a, b) => b.timestamp.localeCompare(a.timestamp));

// Compute deltas from previous run of same model
const runsWithDelta = sortedRuns.map((run, idx) => {
  const prev = sortedRuns.slice(idx + 1).find(r => r.model === run.model);
  const summary = data.model_summaries[run.model];
  const prevSummary = prev ? data.model_summaries[prev.model] : null;
  const delta = prevSummary && summary
    ? Math.round((summary.pass_at_k - prevSummary.pass_at_k) * 10000) / 100
    : null;
  return { ...run, delta };
});
---

<Layout title="Run History">
  <section style="margin-bottom: 2.5rem;">
    <div class="section-label"><span>Pass Rate Over Time</span></div>
    <TimeSeriesChart client:load />
  </section>

  <section>
    <div class="section-label"><span>Run Log ({sortedRuns.length})</span></div>
    <div class="card" style="overflow-x: auto; padding: 1.25rem;">
      <table class="data-table">
        <thead>
          <tr>
            <th>Timestamp</th>
            <th>Model</th>
            <th>Profile</th>
            <th>Reasoning</th>
            <th>Pass</th>
            <th>Suite</th>
            <th>Δ prev</th>
            <th>Git SHA</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {runsWithDelta.map(run => {
            const ts = run.timestamp ? new Date(run.timestamp).toLocaleString() : '—';
            const sha = run.git_sha ? run.git_sha.slice(0, 8) : '—';
            const rl = run.reasoning_level || '—';
            const summary = data.model_summaries[run.model];
            const passRate = summary ? Math.round(summary.pass_at_k * 1000) / 10 : 0;
            const hasDelta = run.delta !== null;
            const deltaCls = hasDelta ? (run.delta! > 0 ? 'var(--pass)' : run.delta! < 0 ? 'var(--fail)' : 'var(--text-dim)') : '';
            return (
              <tr>
                <td style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-dim);">{ts}</td>
                <td>
                  <a href={`/models/${encodeURIComponent(run.model)}`} style="color: var(--text-mid); text-decoration: none; font-family: var(--font-mono); font-size: 0.72rem;">
                    {run.model}
                  </a>
                </td>
                <td style="font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-dim);">{run.profile || '—'}</td>
                <td style="font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-dim);">{rl}</td>
                <td>
                  <span class="result-pill pass" style="font-size: 0.65rem;">{passRate}%</span>
                </td>
                <td style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-dim); opacity: 0.6;">{run.benchmark_suite_version || '—'}</td>
                <td style={`font-family: var(--font-mono); font-size: 0.7rem; color: ${deltaCls};`}>
                  {hasDelta ? (run.delta! >= 0 ? '+' : '') + run.delta + '%' : '—'}
                </td>
                <td style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--accent); opacity: 0.5;">{sha}</td>
                <td>
                  <a href={`/compare?with=${encodeURIComponent(run.model)}`} style="font-family: var(--font-mono); font-size: 0.6rem; color: var(--accent); text-decoration: none;">Compare</a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>
</Layout>
