---
import Layout from '../../components/Layout.astro';
import { loadDataSync } from '../../lib/data';

const data = loadDataSync();
---

<Layout title="Models">
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem;">
    {data.models.map(m => {
      const summary = data.model_summaries[m.name];
      const passRate = summary ? Math.round(summary.pass_at_k * 1000) / 10 : 0;
      const passCls = summary && summary.pass_at_k >= 0.8 ? 'pass' : summary && summary.pass_at_k < 0.5 ? 'fail' : 'warn';
      return (
        <a href={`/models/${encodeURIComponent(m.name)}`} style="text-decoration: none;">
          <div class="card" style="padding: 1.5rem; cursor: pointer; transition: border-color 0.15s;">
            <div style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.4rem; color: var(--text);">{m.name}</div>
            <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
              <span class="result-pill {passCls}" style="font-size: 0.72rem;">{passRate}%</span>
              {m.reasoningLevel && <span class="badge">{m.reasoningLevel}</span>}
            </div>
            {summary && (
              <div style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-dim); margin-top: 0.5rem;">
                {summary.total_passed} / {summary.total_fixtures} fixtures · {summary.total_runs} run(s)
              </div>
            )}
          </div>
        </a>
      );
    })}
  </div>
</Layout>
