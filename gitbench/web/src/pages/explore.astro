---
import Layout from '../components/Layout.astro';
import { loadDataSync } from '../lib/data';
import type { GitBenchData } from '../lib/types';
import { Badge } from '@/components/ui/badge';

const data = loadDataSync();

// Build tag list with counts
const tagCounts: Record<string, number> = {};
const allDiffs = new Set<string>();
for (const fid in data.fixture_index) {
  const fi = data.fixture_index[fid];
  if (fi.difficulty) allDiffs.add(fi.difficulty);
  for (const t of fi.tags) {
    tagCounts[t] = (tagCounts[t] || 0) + 1;
  }
}

const sortedTags = Object.entries(tagCounts).sort(([,a], [,b]) => b - a);
const diffsSorted = Array.from(allDiffs).sort();
const maxCount = Math.max(...sortedTags.map(t => t[1]));

// Build fixture list for client-side filtering
const allFixtures = Object.values(data.fixture_index);
---

<Layout title="Explore">
  <div class="mb-8">
    <div class="section-label"><span>Tag Cloud</span></div>
    <div class="flex gap-1.5 flex-wrap" id="tag-cloud">
      {sortedTags.map(([tag, count]) => {
        const fontSize = Math.max(0.65, Math.min(1.2, 0.65 + (count / maxCount) * 0.55));
        return (
          <span
            class="tag-pill tag-cloud-item cursor-pointer"
            data-tag={tag}
            style={`font-size: ${fontSize.toFixed(2)}rem;`}
          >
            {tag} ({count})
          </span>
        );
      })}
    </div>
  </div>

  <div class="mb-8">
    <div class="section-label"><span>Filters</span></div>
    <div class="flex gap-2 flex-wrap items-center" id="filter-controls">
      <select id="explore-tag" class="bg-[var(--color-card)] text-[var(--color-text)] border border-[var(--color-border)] rounded-md px-2.5 py-1.5 font-mono text-[0.7rem]">
        <option value="">Any tag</option>
        {sortedTags.map(([tag]) => <option value={tag}>{tag}</option>)}
      </select>
      <select id="explore-diff" class="bg-[var(--color-card)] text-[var(--color-text)] border border-[var(--color-border)] rounded-md px-2.5 py-1.5 font-mono text-[0.7rem]">
        <option value="">Any difficulty</option>
        {diffsSorted.map(d => <option value={d}>{d}</option>)}
      </select>
      <select id="explore-bench" class="bg-[var(--color-card)] text-[var(--color-text)] border border-[var(--color-border)] rounded-md px-2.5 py-1.5 font-mono text-[0.7rem]">
        <option value="">Any benchmark</option>
        {data.benchmarks.map(b => <option value={b}>{b}</option>)}
      </select>
      <button onclick="resetExploreFilters()" class="bg-transparent border border-[var(--color-border)] text-[var(--color-text-dim)] rounded-md px-2.5 py-1.5 font-mono text-[0.65rem] cursor-pointer">
        Reset
      </button>
    </div>
  </div>

  <section>
    <div class="section-label">
      <span>Results</span>
      <span id="result-count" class="font-mono text-xs text-[var(--color-text-dim)]"></span>
    </div>
    <div class="flex flex-col gap-2.5" id="explore-results">
      {allFixtures.map(fi => (
        <div
          class="card explore-result p-4 flex justify-between items-center flex-wrap gap-3 cursor-pointer"
          data-tags={fi.tags.join(',')}
          data-diff={fi.difficulty}
          data-bench={fi.benchmark}
          onclick={`window.location='/fixtures/${encodeURIComponent(fi.benchmark)}/${fi.id}'`}
        >
          <div class="flex gap-2 items-center flex-wrap">
            <span class="font-mono text-xs text-[var(--color-text-mid)] font-medium">{fi.id}</span>
            <Badge variant="secondary" class="font-mono text-[0.6rem]">{fi.benchmark}</Badge>
            {fi.difficulty && (
              <Badge variant="outline" class="font-mono text-[0.55rem] opacity-50 border-[var(--color-pass-border)] text-[var(--color-pass)]">
                {fi.difficulty}
              </Badge>
            )}
          </div>
          <div class="flex gap-1 flex-wrap">
            {fi.tags.slice(0, 3).map(t => (
              <Badge variant="secondary" class="font-mono text-[0.55rem] px-1 py-0">{t}</Badge>
            ))}
            {fi.tags.length > 3 && (
              <span class="font-mono text-[0.6rem] text-[var(--color-text-dim)]">+{fi.tags.length - 3}</span>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<script>
  function applyExploreFilters() {
    const tag = (document.getElementById('explore-tag') as HTMLSelectElement)?.value || '';
    const diff = (document.getElementById('explore-diff') as HTMLSelectElement)?.value || '';
    const bench = (document.getElementById('explore-bench') as HTMLSelectElement)?.value || '';
    const results = document.querySelectorAll('.explore-result');
    let visible = 0;
    results.forEach((el: any) => {
      const tags = (el.dataset.tags || '').split(',');
      const d = el.dataset.diff || '';
      const b = el.dataset.bench || '';
      const show = (!tag || tags.includes(tag))
        && (!diff || d === diff)
        && (!bench || b === bench);
      el.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    const countEl = document.getElementById('result-count');
    if (countEl) countEl.textContent = `(${visible} fixture${visible !== 1 ? 's' : ''})`;
  }
  function resetExploreFilters() {
    ['explore-tag', 'explore-diff', 'explore-bench'].forEach(id => {
      const el = document.getElementById(id) as HTMLSelectElement;
      if (el) el.value = '';
    });
    applyExploreFilters();
  }
  document.getElementById('explore-tag')?.addEventListener('change', applyExploreFilters);
  document.getElementById('explore-diff')?.addEventListener('change', applyExploreFilters);
  document.getElementById('explore-bench')?.addEventListener('change', applyExploreFilters);
  document.querySelectorAll('.tag-cloud-item').forEach(el => {
    el.addEventListener('click', () => {
      const tag = (el as HTMLElement).dataset.tag || '';
      const select = document.getElementById('explore-tag') as HTMLSelectElement;
      if (select) { select.value = tag; }
      applyExploreFilters();
    });
  });
  applyExploreFilters();

  // Handle ?tag= query param
  const params = new URLSearchParams(window.location.search);
  const initialTag = params.get('tag');
  if (initialTag) {
    const select = document.getElementById('explore-tag') as HTMLSelectElement;
    if (select) { select.value = initialTag; }
    applyExploreFilters();
  }
</script>
